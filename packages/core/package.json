{
  "name": "@reminisce/core",
  "version": "0.2.0",
  "description": "Core types, schemas, and utilities for Reminisce",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./salience": {
      "types": "./dist/salience/index.d.ts",
      "import": "./dist/salience/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^9.0.0",
