{
  "name": "@reminisce/api",
  "version": "0.2.0",
  "description": "HTTP API server for Reminisce dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/index.ts",
    "start": "bun run dist/index.js",
    "test": "bun test"
  },
  "dependencies": {
    "@reminisce/orchestrator": "^0.2.0",
    "@reminisce/core": "^0.2.0",
    "@reminisce/storage-sqlite": "^0.2.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
